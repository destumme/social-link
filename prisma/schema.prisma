// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TraitCategory {
  CONTACT_INFO
  MAILING_ADDRESS
  SOCIAL_LINK
  PROFESSIONAL_LINK
  WEBSITE_LINK
  MESSAGING_HANDLE
  OTHER
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Account {
  id               String            @id @default(uuid())
  displayName      String
  username         String            @unique
  publicListed     Boolean           @default(true)
  traits           Trait[]
  connections      Connection[]      @relation("connections")
  connectionGroups ConnectionGroup[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  connectedTo      Connection[]      @relation("connectedTo")
}

model Trait {
  id            String            @id @default(uuid())
  key           String
  value         String
  category      TraitCategory?
  icon          String?
  visibleGroups ConnectionGroup[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  account       Account?          @relation(fields: [accountId], references: [id])
  accountId     String?
}

model Connection {
  id                 String            @id @default(uuid())
  connectedAccount   Account?          @relation("connectedTo", fields: [connectedAccountId], references: [id])
  connectedAccountId String?
  status             ConnectionStatus
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  account            Account?          @relation("connections", fields: [accountId], references: [id])
  accountId          String?
  connectionGroups   ConnectionGroup[]
}

model ConnectionGroup {
  id          String       @id @default(uuid())
  name        String
  connections Connection[]
  traits      Trait[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  account     Account?     @relation(fields: [accountId], references: [id])
  accountId   String?
}
